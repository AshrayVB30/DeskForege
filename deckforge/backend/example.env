# ============================================================
# DeckForge Backend — Environment Variables Reference
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================


# ----------------------------------------
# MongoDB
# ----------------------------------------

# MongoDB Atlas connection URI
# Format: mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/
DATABASE_URL=mongodb+srv://<your_mongo_username>:<your_mongo_password>@cluster0.xxxx.mongodb.net/

# ----------------------------------------
# Application Security
# ----------------------------------------

# A long, random string used to sign JWT tokens.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_random_secret_key_here

# ----------------------------------------
# Google Gemini (Primary AI — used for slide generation)
# ----------------------------------------

# API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here

# ----------------------------------------
# Azure OpenAI (Optional — secondary AI provider)
# ----------------------------------------

# API key for Azure OpenAI service
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here

# Endpoint for Azure OpenAI service
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/

# API version for Azure OpenAI
API_VERSION=2024-05-01-preview

# Deployed model name in Azure (e.g. "gpt-4o")
AZURE_DEPLOYMENT=gpt-4o

# ----------------------------------------
# LLM Farm (Optional — internal/proxy routing)
# ----------------------------------------

# Base URL for LLM Farm API
LLMFARM_API_URL=https://<your-llmfarm-host>/api

# API key for LLM Farm access
LLMFARM_API_KEY=your_llmfarm_api_key_here

# Deployment name on LLM Farm
LLMFARM_CHAT_DEPLOYMENT_OPENAI=your_llmfarm_chat_deployment_name

# Chat API version used for LLM Farm
LLMFARM_CHAT_VERSION=2024-08-01-preview

# ----------------------------------------
# Super OPL (Optional — internal service)
# ----------------------------------------

# Key for Super OPL service
SUPER_OPL_KEY=your_super_opl_key_here

# ----------------------------------------
# DALL·E – Azure OpenAI (Optional — image generation)
# ----------------------------------------

# Azure Cognitive Services endpoint for DALL·E
DALLE_OPENAI_ENDPOINT=https://<your-cognitive-services-resource>.cognitiveservices.azure.com

# Full endpoint for DALL·E 3 image generation API
DALLE_OPENAI_ENDPOINT_2=https://<your-cognitive-services-resource>.cognitiveservices.azure.com/openai/deployments/dall-e-3/images/generations?api-version=2024-02-01

# Deployment name for DALL·E 3 on Azure
DALLE_AZURE_DEPLOYMENT=dall-e-3

# API version for DALL·E image generation
DALLE_API_VERSION=2024-02-01

# API key for DALL·E (Azure Cognitive Services)
DALLE_OPENAI_API_KEY=your_dalle_azure_api_key_here